# Large/generated datasets: keep directory skeleton via .gitkeep, ignore actual contents.
data/clean/**
!data/clean/**/
!data/clean/**/.gitkeep

data/degraded/**
!data/degraded/**/
!data/degraded/**/.gitkeep

data/tool_datasets/**
!data/tool_datasets/**/
!data/tool_datasets/**/.gitkeep

data/reference/**
!data/reference/**/
!data/reference/**/.gitkeep
!data/reference/reference_manifest.jsonl

data/qc_reports/**
!data/qc_reports/**/
!data/qc_reports/**/.gitkeep

runs/**
!runs/**/
!runs/**/.gitkeep

outputs/
output/
checkpoints/
ckpt/
*.pth
*.pt
*.ckpt
*.onnx
*.log
__pycache__/
*.pyc
.DS_Store
