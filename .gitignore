!data/clean/**/.gitkeep

data/degraded/**
!data/degraded/**/
!data/degraded/**/.gitkeep

data/tool_datasets/**
!data/tool_datasets/**/
!data/tool_datasets/**/.gitkeep

data/reference/**
!data/reference/**/
!data/reference/**/.gitkeep
!data/reference/reference_manifest.jsonl

data/qc_reports/**
!data/qc_reports/**/
!data/qc_reports/**/.gitkeep

runs/**
!runs/**/
!runs/**/.gitkeep

outputs/**
!outputs/**/
!outputs/**/.gitkeep

output/**
!output/**/
!output/**/.gitkeep

checkpoints/**
!checkpoints/**/
!checkpoints/**/.gitkeep

ckpt/**
!ckpt/**/
!ckpt/**/.gitkeep

exports/**
!exports/**/
!exports/**/.gitkeep

reports/**
!reports/**/
!reports/**/.gitkeep

*.pth
*.pt
*.ckpt
*.onnx
*.log
__pycache__/
*.pyc
.DS_Store
# local patches and generated archives
*.zip
*.tar
*.tar.gz

